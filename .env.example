# Required for real API mode
OPENAI_API_KEY=your_api_key_here

# Lightweight default model (change as needed)
OPENAI_MODEL=gpt-4.1-mini

# Optional: force mock mode for local UI testing
OPENAI_MOCK=false

# Optional: inactivity period (seconds) before backend recommends sleep
INACTIVITY_SECONDS=120

# Optional: edge-tts Japanese voice
TTS_VOICE=ja-JP-NanamiNeural
